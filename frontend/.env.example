# Frontend environment variables
# For npm run dev: copy to frontend/.env.local
# For Docker: set VITE_* in the root .env file and run docker compose up --build

VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
# reCAPTCHA v2 checkbox — site key only (secret stays on backend).
# Create keys: https://www.google.com/recaptcha/admin/create → v2 Checkbox
# Domains: localhost (+ your Render hostname when deployed)
# Full guide: ../docs/RECAPTCHA_SETUP.md
VITE_RECAPTCHA_SITE_KEY=
